// Mirror — PRODUCTION schema (PostgreSQL).
// This is identical to schema.prisma except the datasource provider,
// which is "postgresql" here for serverless deployment (Vercel + Neon).
//
// Keep these two schemas in sync. The model definitions must match.
// Local dev uses schema.prisma (SQLite); production uses this file.
//
// Vercel builds with: --schema=prisma/schema.prod.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// The subject of reflection — the person looking into the mirror.
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  selfAssessments  SelfAssessment[]
  invitations      Invitation[]
  selectedBehaviors UserBehavior[]
}

// An observable behavior. Never a label, never a diagnosis.
// Always phrased so it can be witnessed and rated on frequency.
model Behavior {
  id        String   @id @default(cuid())
  text      String   @unique
  category  String
  createdAt DateTime @default(now())

  userBehaviors     UserBehavior[]
  selfAssessments   SelfAssessment[]
  feedback          Feedback[]
}

// A behavior the user has chosen to be assessed on.
model UserBehavior {
  id         String   @id @default(cuid())
  userId     String
  behaviorId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  behavior Behavior @relation(fields: [behaviorId], references: [id], onDelete: Cascade)

  @@unique([userId, behaviorId])
}

// How the user rates themselves on a behavior. Self-perception.
model SelfAssessment {
  id         String   @id @default(cuid())
  userId     String
  behaviorId String
  rating     Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  behavior Behavior @relation(fields: [behaviorId], references: [id], onDelete: Cascade)

  @@unique([userId, behaviorId])
}

// A confidential invitation to someone in one of the user's circles.
// Confidential, not anonymous: we know the circle, we hide the individual.
model Invitation {
  id           String    @id @default(cuid())
  token        String    @unique @default(cuid())
  userId       String
  providerName String
  circle       String
  status       String    @default("pending")
  createdAt    DateTime  @default(now())
  completedAt  DateTime?

  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedback Feedback[]

  @@index([userId])
}

// A single provider's rating of the user on a single behavior.
// External reality. Always tied to an invitation (and thus a circle).
model Feedback {
  id           String   @id @default(cuid())
  invitationId String
  behaviorId   String
  rating       Float
  createdAt    DateTime @default(now())

  invitation Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  behavior   Behavior   @relation(fields: [behaviorId], references: [id], onDelete: Cascade)

  @@unique([invitationId, behaviorId])
  @@index([behaviorId])
}
