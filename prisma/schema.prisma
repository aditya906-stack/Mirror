// Mirror — evidence-based behavioral reflection platform
// The data model exists to compute one thing: the gap between
// how a person sees themselves and how their circles experience them.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// The subject of reflection — the person looking into the mirror.
// Auth is username + password. Email is optional (for future verification).
// `name` is the display name shown on invitations to circles.
model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  name         String
  email        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  selfAssessments  SelfAssessment[]
  invitations      Invitation[]
  selectedBehaviors UserBehavior[]
}

// An observable behavior. Never a label, never a diagnosis.
// Always phrased so it can be witnessed and rated.
//
// `format` controls how the question is presented:
//   frequency — the behavior text + Never→Almost always scale (1-5)
//   agreement — the behavior text + Strongly disagree→Strongly agree (1-5)
//   scenario  — `prompt` (a situation with {subject}) + `options` (5 choices, 1-5)
// The stored rating is always 1-5 regardless of format, so the gap
// between self-perception and external reality stays mathematically sound.
model Behavior {
  id        String   @id @default(cuid())
  text      String   @unique
  category  String
  format    String   @default("frequency")
  prompt    String?
  options   String?
  createdAt DateTime @default(now())

  userBehaviors     UserBehavior[]
  selfAssessments   SelfAssessment[]
  feedback          Feedback[]
}

// A behavior the user has chosen to be assessed on.
model UserBehavior {
  id         String   @id @default(cuid())
  userId     String
  behaviorId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  behavior Behavior @relation(fields: [behaviorId], references: [id], onDelete: Cascade)

  @@unique([userId, behaviorId])
}

// How the user rates themselves on a behavior. Self-perception.
model SelfAssessment {
  id         String   @id @default(cuid())
  userId     String
  behaviorId String
  rating     Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  behavior Behavior @relation(fields: [behaviorId], references: [id], onDelete: Cascade)

  @@unique([userId, behaviorId])
}

// A confidential invitation to someone in one of the user's circles.
// Confidential, not anonymous: we know the circle, we hide the individual.
model Invitation {
  id           String    @id @default(cuid())
  token        String    @unique @default(cuid())
  userId       String
  providerName String
  circle       String
  status       String    @default("pending")
  createdAt    DateTime  @default(now())
  completedAt  DateTime?

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedback          Feedback[]
  characterFeedback CharacterFeedback[]

  @@index([userId])
}

// A single provider's rating of the user on a single behavior.
// External reality. Always tied to an invitation (and thus a circle).
model Feedback {
  id           String   @id @default(cuid())
  invitationId String
  behaviorId   String
  rating       Float
  createdAt    DateTime @default(now())

  invitation Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  behavior   Behavior   @relation(fields: [behaviorId], references: [id], onDelete: Cascade)

  @@unique([invitationId, behaviorId])
  @@index([behaviorId])
}

// A provider's answer to a CHARACTER question (the friend-only instrument).
// These questions are NOT the behavioral self-assessment — they are a
// separate set the friend answers about the subject, designed to reveal
// character patterns. See src/lib/character.ts for the question definitions.
// `questionId` references the static question id in character.ts.
model CharacterFeedback {
  id           String   @id @default(cuid())
  invitationId String
  questionId   String
  rating       Int
  createdAt    DateTime @default(now())

  invitation Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  @@unique([invitationId, questionId])
  @@index([questionId])
}
